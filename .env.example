# ============================================================================
# .env.example — copy to .env (gitignored) and fill in real values.
#
# Config comes from the ENVIRONMENT and is validated at STARTUP; the app fails
# loudly on missing/invalid config (docs/ARCHITECTURE.md §4, docs/SECURITY.md §1).
# NEVER commit real secrets — only this example file is tracked.
# Stack: ADR-0001 (TS · React+Vite · Fastify) · ADR-0002 (PostgreSQL · Kysely).
# ============================================================================

# Runtime environment: development | test | production
APP_ENV=development

# --- API server (apps/api) ---
PORT=3001
LOG_LEVEL=info

# --- Datastore (per ADR-0002) ---
# In dev/test the API uses an in-process PGlite database (no server needed) when
# DATABASE_URL is unset. In production set a real PostgreSQL connection string.
# DATABASE_URL=postgres://user:password@host:5432/budgeteer

# --- Web app (apps/web) ---
# Base URL the browser uses to reach the API.
VITE_API_BASE_URL=http://localhost:3001
