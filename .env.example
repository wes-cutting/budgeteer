# ============================================================================
# .env.example — copy to .env at the REPO ROOT (gitignored) and fill in values.
#
# This repo-root .env is AUTO-LOADED: the API loads it via dotenv (apps/api),
# the web app via Vite's envDir (apps/web) — one shared file for both. Real
# process env vars still take precedence over .env.
#
# Config comes from the ENVIRONMENT and is validated at STARTUP; the app fails
# loudly on missing/invalid config (docs/ARCHITECTURE.md §4, docs/SECURITY.md §1).
# NEVER commit real secrets — only this example file is tracked. Vite exposes
# ONLY VITE_-prefixed vars to the browser; everything else stays server-side.
# Stack: ADR-0001 (TS · React+Vite · Fastify) · ADR-0002 (PostgreSQL · Kysely).
# ============================================================================

# Runtime environment: development | test | production
APP_ENV=development

# --- API server (apps/api) ---
PORT=3001
LOG_LEVEL=info

# Browser origins allowed to call the API (CORS), comma-separated. An ALLOWLIST, never `*`
# (docs/SECURITY.md §2). Defaults to the Vite dev origins; set explicitly per environment
# (e.g. your deployed web origin in production).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Datastore (per ADR-0002) ---
# In dev/test the API uses an in-process PGlite database (no server needed) when
# DATABASE_URL is unset. In production set a real PostgreSQL connection string.
# DATABASE_URL=postgres://user:password@host:5432/budgeteer

# Optional: persist the dev PGlite store to a local directory so data survives server restarts
# and `npm run seed` (in apps/api) writes to the same store the server reads. Path is relative
# to apps/api when running npm scripts. The repo-root /data/ dir is already gitignored.
# Ignored when DATABASE_URL is set. Leave unset to keep the fast in-memory default for dev/test.
# PGLITE_DIR=../../data/budgeteer-dev

# --- Web app (apps/web) ---
# Base URL the browser uses to reach the API.
VITE_API_BASE_URL=http://localhost:3001
