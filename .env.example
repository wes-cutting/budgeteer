# ============================================================================
# .env.example — copy to .env (which is gitignored) and fill in real values.
#
# Configuration comes from the ENVIRONMENT and is validated at STARTUP; the app
# fails loudly on missing/invalid config (docs/ARCHITECTURE.md §4, docs/SECURITY.md §1).
# NEVER commit real secrets — only this example file is tracked (the .gitignore
# allows it via `!.env.example`). Real values live in your local .env or the
# deployment secret store, never in the repo.
#
# This file is stack-agnostic: the keys below are ILLUSTRATIVE. Replace them with
# your project's actual config (per ADR-0001 / ADR-0002) and delete what you don't use.
# ============================================================================

# Runtime environment: development | test | production
APP_ENV=development

# --- Server (example) ---
# PORT=3000
# LOG_LEVEL=info

# --- Datastore (example, per ADR-0002) ---
# Keep credentials out of source control; in production prefer a secret store.
# DATABASE_URL=

# --- Secrets (example) ---
# Generate strong, unique random values per environment; never reuse or commit them.
# SESSION_SECRET=
# API_KEY=
