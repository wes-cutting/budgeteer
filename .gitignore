# ============================================================================
node_modules/
.pnpm-store/
vendor/
.venv/
venv/
__pycache__/
target/

# ============================================================================
# BUILD / OUTPUT
# ============================================================================
dist/
build/
out/
coverage/
*.tsbuildinfo
.next/
.cache/

# Playwright e2e artifacts (browser binaries live in ~/.cache, not the repo)
test-results/
playwright-report/
blob-report/
.last-run.json

# ============================================================================
# LOGS & TMP
# ============================================================================
*.log
tmp/
.tmp/

# ============================================================================
# OS / EDITOR
# ============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/
# Agent-spawned worktrees (K28): ESLint doesn't honor .gitignore, but a stale worktree left
# behind by a tool session shouldn't be tracked either way — and this line is the reminder.
**/worktrees/**
